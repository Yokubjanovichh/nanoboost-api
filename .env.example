# Application
ENVIRONMENT=dev

# Database
DATABASE_URL=postgresql+asyncpg://nanoboost:nanoboost@postgres:5432/nanoboost

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Storage
STORAGE_BACKEND=local
UPLOADS_DIR=uploads
UPLOADS_URL_PREFIX=/uploads
MAX_UPLOAD_SIZE_BYTES=5242880

# Redis cache (optional). Leave blank to disable — endpoints will serve
# with X-Cache: BYPASS instead of HIT/MISS.
REDIS_URL=redis://redis:6379/0

# Notifications master toggle
NOTIFICATIONS_ENABLED=true

# Telegram bot
TG_ENABLED=true
TG_BOT_TOKEN=
TG_CHAT_ID=

# Email (SMTP)
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=orders@nanoboost.io
NOTIFY_EMAIL=admin@nanoboost.io

# Payment infrastructure
PUBLIC_SITE_URL=https://nanoboost.io
ECOMTRADE24_API_KEY=
ECOMTRADE24_WEBHOOK_SECRET=
ECOMTRADE24_BASE_URL=https://pay.ecomtrade24.com
ECOMTRADE24_DOMAIN=nanoboost.io

# Seed superuser (used by scripts.create_superuser)
SEED_SUPERUSER_EMAIL=admin@nanoboost.io
SEED_SUPERUSER_PASSWORD=ChangeMeImmediately123!
SEED_SUPERUSER_NAME=Root Admin
