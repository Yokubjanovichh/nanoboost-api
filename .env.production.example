# Production environment template — copy values into Railway dashboard
# (Variables → Secret) rather than committing real values to git.

ENVIRONMENT=prod

# --- Database -----------------------------------------------------------
# Railway Postgres plugin injects DATABASE_URL automatically. Leave blank
# locally. Format: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=

# --- JWT ----------------------------------------------------------------
# Generate once with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---------------------------------------------------------------
CORS_ORIGINS=["https://admin.nanoboost.io","https://nanoboost.io"]

# --- Storage ------------------------------------------------------------
STORAGE_BACKEND=local
UPLOADS_DIR=/app/uploads
UPLOADS_URL_PREFIX=/uploads
MAX_UPLOAD_SIZE_BYTES=5242880

# --- Notifications: master ---------------------------------------------
NOTIFICATIONS_ENABLED=true

# --- Notifications: Telegram -------------------------------------------
TG_ENABLED=true
TG_BOT_TOKEN=
TG_CHAT_ID=

# --- Notifications: SMTP -----------------------------------------------
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=orders@nanoboost.io
NOTIFY_EMAIL=admin@nanoboost.io

# --- Initial superuser (seeded once on first deploy) -------------------
# Change immediately after first login via PATCH /api/v1/users/{id}
SEED_SUPERUSER_EMAIL=admin@nanoboost.io
SEED_SUPERUSER_PASSWORD=
SEED_SUPERUSER_NAME=Root Admin
